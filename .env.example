# Database (Prisma + SQLite by default)
DATABASE_URL="file:./dev.db"

# === Contact Form Backend Configuration ===

# Your email address (receives contact form submissions)
OWNER_EMAIL="aarav.sharma.dev@gmail.com"

# Optional but recommended: Resend API key for real email delivery
# Get a free key at https://resend.com (very generous free tier)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# === Admin Panel Protection ===
# Set a strong secret token. Then access messages at:
#   https://yourdomain.com/admin?token=YOUR_ADMIN_TOKEN_HERE
#
# If left empty, the /admin page will be open (convenient for local dev).
ADMIN_TOKEN=""

# When deploying to production (Vercel, etc):
# 1. Use Postgres instead of SQLite:
#    DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
# 2. Add RESEND_API_KEY + ADMIN_TOKEN
# 3. (Recommended) Switch generator to use Accelerate or just keep direct connection.
