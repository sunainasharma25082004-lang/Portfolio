# =====================================================
# ENVIRONMENT VARIABLES - Sunaina Sharma Portfolio
# =====================================================
# Copy this file and rename to .env.local (for local dev)
# or .env (for some setups)
#
#   cp .env.example .env.local
#
# NEVER commit real .env files with secrets!
# =====================================================

# -----------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------
# For Render: Automatically provided when you attach a Postgres database via render.yaml
# For local development: Use Neon, Supabase, or local Postgres
# Example local: postgresql://postgres:password@localhost:5432/portfolio
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# -----------------------------------------------------
# RESEND - Email Notifications (Recommended)
# -----------------------------------------------------
# Sign up free at https://resend.com
# Used to send email alerts when someone submits contact form or a review.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# Email address that will receive contact messages and new review notifications
OWNER_EMAIL="sunainasharma25082004@gmail.com"

# -----------------------------------------------------
# ADMIN DASHBOARD PROTECTION (Required)
# -----------------------------------------------------
# A strong secret token used to access the admin panel.
# Usage: https://your-site.com/admin?token=YOUR_ADMIN_TOKEN_HERE
#
# Generate a strong one:
#   - On Mac/Linux:   openssl rand -base64 32
#   - On Windows:     Use https://www.random.org/strings or PowerShell:
#                     [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
ADMIN_TOKEN="your-super-strong-random-admin-token-here"

# -----------------------------------------------------
# OPTIONAL / DEVELOPMENT ONLY
# -----------------------------------------------------
# NODE_ENV is usually set automatically by Next.js / Render
# NODE_ENV="production"

# These are only relevant if you are still using the old separate backend/ folder
# (not recommended after the production consolidation)
# PORT=5000
# ALLOWED_ORIGIN="http://localhost:3000"
# MONGO_URI="mongodb+srv://..."

# -----------------------------------------------------
# NOTES
# -----------------------------------------------------
# - On Render, DATABASE_URL is auto-injected via the database service in render.yaml
# - After first deploy on Render, manually add: RESEND_API_KEY, OWNER_EMAIL, ADMIN_TOKEN
# - For local Postgres testing, install Postgres or use a free cloud provider (Neon/Supabase recommended)
